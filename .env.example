# ─── Neurospark Corporation — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit real secrets.

# WhatsApp contact number (without the + prefix, include country code)
# Used in: WhatsAppWidget.jsx, FinalCTA.jsx, Footer.jsx, ErrorBoundary.jsx
VITE_WHATSAPP_NUMBER=254799644100

# Plausible Analytics domain (must match domain registered on plausible.io)
VITE_PLAUSIBLE_DOMAIN=neurosparkcorporation.ai

# Formspree form ID — the part after /f/ in your endpoint URL (e.g. "xpwzabcd")
# v3.1: moved from hardcoded string in ContactPage.jsx to env var (SEC-04)
# Find your form ID at: formspree.io → your form → Settings
# Also set this in Vercel dashboard → Project → Settings → Environment Variables
VITE_FORMSPREE_ID=xqeykybz

# Resend API key — for a future serverless contact form (v2.6 scope, not yet used)
# RESEND_API_KEY=re_xxxxxxxxxxxx
