# ─── Neurospark Corporation — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit real secrets.

# WhatsApp contact number (without the + prefix, include country code)
# Used in: WhatsAppWidget.jsx, FinalCTA.jsx, Footer.jsx, ErrorBoundary.jsx
VITE_WHATSAPP_NUMBER=254799644100

# Plausible Analytics domain (must match domain registered on plausible.io)
VITE_PLAUSIBLE_DOMAIN=neurosparkcorporation.ai

# Resend API key — for the real contact form (v2.6 feature, not yet used)
# RESEND_API_KEY=re_xxxxxxxxxxxx
